{
  "name": "omnitask-backend",
  "version": "1.0.0",
  "description": "Enterprise Task Management Backend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node scripts/prepare-build.mjs && node esbuild.config.mjs",
    "build:prod": "cross-env NODE_ENV=production node scripts/prepare-build.mjs && node esbuild.config.mjs",
    "start": "node dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:clear": "tsx clear-db.ts",
    "db:seed": "prisma db seed",
    "db:format": "prisma format"
  },
  "keywords": [
    "fastify",
    "prisma",
    "socket.io"
  ],
  "author": "Himanshu",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.24.0",
    "glob": "^13.0.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
