{
  "compilerOptions": {
    /* Core */
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* Paths */
    "rootDir": "./",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./src/*"],
      "@/controllers/*": ["./src/modules/*"],
      "@/middlewares/*": ["./src/middlewares/*"],
      "@/plugins/*": ["./src/plugins/*"],
      "@/repositories/*": ["./src/repositories/*"],
      "@/routes/*": ["./src/routes/*", "./src/modules/*"],
      "@/services/*": ["./src/modules/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/config/*": ["./src/config/*"],
      "@/lib/*": ["./src/lib/*"]
    },

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Node */
    "types": ["node"],

    /* DX */
    "skipLibCheck": true,
    "sourceMap": true,

    /* Optional but useful */
    "resolveJsonModule": true,

    /* Decorators */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*", "src/types/**/*.d.ts", "src/types.d.ts", "prisma/**/*"]
}